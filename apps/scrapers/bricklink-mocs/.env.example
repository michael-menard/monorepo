# Scraper Database (bricklink-mocs specific tables)
SCRAPER_DB_HOST=localhost
SCRAPER_DB_PORT=5432
SCRAPER_DB_USER=postgres
SCRAPER_DB_PASSWORD=postgres
SCRAPER_DB_NAME=rebrickable

# Gallery Database (shared app DB)
GALLERY_DB_HOST=localhost
GALLERY_DB_PORT=5432
GALLERY_DB_USER=postgres
GALLERY_DB_PASSWORD=postgres
GALLERY_DB_NAME=monorepo

# MinIO / S3
NODE_ENV=development
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
SCRAPER_BUCKET=rebrickable-instructions

# Gallery sync (Cognito user ID)
SYNC_USER_ID=

# Notifications server
NOTIFICATIONS_SERVER_URL=http://localhost:3098
NOTIFICATIONS_HMAC_SECRET=

# Rate limiting (per-hour cap across all process invocations)
SCRAPER_MAX_PER_HOUR=20

# Browser
SCRAPER_HEADED=false
