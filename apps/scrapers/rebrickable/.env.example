# Database
SCRAPER_DB_HOST=localhost
SCRAPER_DB_PORT=5432
SCRAPER_DB_USER=postgres
SCRAPER_DB_PASSWORD=postgres
SCRAPER_DB_NAME=rebrickable

# Rebrickable credentials
REBRICKABLE_USERNAME=your_username
REBRICKABLE_PASSWORD=your_password

# MinIO / S3
NODE_ENV=development
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
SCRAPER_BUCKET=rebrickable-instructions

# Scraper tuning
SCRAPER_RATE_LIMIT=10
SCRAPER_MIN_DELAY_MS=2000
SCRAPER_HEADED=false
