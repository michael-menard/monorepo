{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lego-moc-platform.com/schemas/user-flows.schema.json",
  "title": "User Flows Schema",
  "description": "Schema for defining user flows with required states and capabilities. Enables PO cohesion checks for feature completeness.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the schema (e.g., 1.0.0)"
    },
    "featureName": {
      "type": "string",
      "description": "Optional feature name for context"
    },
    "flows": {
      "type": "array",
      "description": "Array of user flows for the feature",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/UserFlow"
      }
    }
  },
  "required": ["schema_version", "flows"],
  "$defs": {
    "UserFlowState": {
      "type": "string",
      "enum": ["loading", "empty", "validation_error", "server_error", "permission_denied"],
      "description": "Required states that all user flows must handle"
    },
    "UserFlowCapability": {
      "type": "string",
      "enum": ["create", "view", "edit", "delete", "upload", "replace", "download"],
      "description": "Standard capabilities mapped to CRUD operations"
    },
    "UserFlowStep": {
      "type": "object",
      "description": "A single step within a user flow",
      "properties": {
        "stepName": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the step"
        },
        "state": {
          "$ref": "#/$defs/UserFlowState"
        },
        "capabilities": {
          "type": "array",
          "description": "Capabilities available in this step",
          "minItems": 0,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/UserFlowCapability"
          }
        },
        "description": {
          "type": "string",
          "description": "Optional description of the step"
        }
      },
      "required": ["stepName", "state", "capabilities"]
    },
    "UserFlow": {
      "type": "object",
      "description": "A complete user flow with multiple steps",
      "properties": {
        "flowName": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the flow"
        },
        "description": {
          "type": "string",
          "description": "Optional description of the flow"
        },
        "steps": {
          "type": "array",
          "description": "Steps within the flow",
          "minItems": 1,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/UserFlowStep"
          }
        }
      },
      "required": ["flowName", "steps"]
    }
  }
}
