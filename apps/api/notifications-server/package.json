{
  "name": "@repo/notifications-server",
  "version": "1.0.0",
  "description": "Notifications Server - Bun + Hono + Socket.io",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "tsc",
    "lint": "eslint --fix src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@repo/logger": "workspace:*",
    "dotenv": "^16.4.5",
    "hono": "^4.7.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
