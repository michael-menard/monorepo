{
  "name": "@repo/pipeline",
  "version": "0.0.1",
  "description": "Autonomous pipeline supervisor with parallel worktree concurrency",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "@repo/orchestrator": "workspace:*",
    "bullmq": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.10",
    "@vitest/coverage-v8": "^3.2.4",
    "ioredis": "^5.4.2",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
