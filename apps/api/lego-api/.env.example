# =============================================================================
# lego-api Environment Variables
# =============================================================================

# Prometheus Metrics
# Set to "true" to activate the /metrics endpoint for Prometheus scraping.
# Required for local observability stack — Prometheus scrapes this endpoint
# via host.docker.internal:3001/metrics (configured in infra/prometheus/prometheus.yml).
# Without this, Prometheus will show the lego-api target as DOWN.
ENABLE_METRICS=true
