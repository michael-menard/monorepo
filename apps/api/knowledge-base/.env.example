# Knowledge Base Database Configuration
# Copy this file to .env and adjust values as needed
#
# IMPORTANT: Port 5433 is used by default to avoid conflict with root docker-compose (port 5432)
#
# SECURITY WARNING: KB_DB_USER and KB_DB_PASSWORD are REQUIRED.
# Change these values immediately. Never commit real credentials to version control.

# Database host (use 'localhost' for local development)
KB_DB_HOST=localhost

# Database port (default: 5433 to avoid conflict with root docker-compose)
KB_DB_PORT=5433

# Database name
KB_DB_NAME=knowledgebase

# Database user (REQUIRED - must be set explicitly)
KB_DB_USER=kbuser

# Database password (REQUIRED - must be set explicitly)
# SECURITY: Password must meet the following requirements:
#   - Minimum 16 characters
#   - At least one uppercase letter (A-Z)
#   - At least one lowercase letter (a-z)
#   - At least one number (0-9)
#   - At least one special character (!@#$%^&*, etc.)
# Example: MySecureKnowledgeBase2024!
KB_DB_PASSWORD=

# Connection pool settings (optimized for Lambda context)
# Maximum number of connections in the pool
KB_DB_MAX_CONNECTIONS=10

# Idle timeout in milliseconds (release connections quickly in serverless context)
KB_DB_IDLE_TIMEOUT_MS=10000

# Connection timeout in milliseconds (fail fast)
KB_DB_CONNECTION_TIMEOUT_MS=5000

# ============================================================================
# OpenAI Embedding Configuration (KNOW-002)
# ============================================================================

# OpenAI API Key (REQUIRED for embedding generation)
# Get your API key from: https://platform.openai.com/api-keys
# SECURITY: Never commit this value to version control
OPENAI_API_KEY=

# Embedding model to use (default: text-embedding-3-small)
# Options:
#   - text-embedding-3-small (1536 dimensions, $0.00002 per 1K tokens) - RECOMMENDED
#   - text-embedding-3-large (3072 dimensions, $0.00013 per 1K tokens)
# Note: Changing the model requires database migration to update vector dimensions
EMBEDDING_MODEL=text-embedding-3-small

# Request timeout in milliseconds (default: 30000)
# How long to wait for OpenAI API response before timing out
OPENAI_TIMEOUT_MS=30000

# Number of retry attempts for transient failures (default: 3)
# Applies to rate limits (429), server errors (500), and timeouts
# Total retry delay: ~7 seconds with exponential backoff (1s, 2s, 4s)
OPENAI_RETRY_COUNT=3

# Maximum concurrent requests to OpenAI API (default: 10)
# Controls rate limit throttling for batch operations
# Lower this if you hit rate limits frequently
OPENAI_MAX_CONCURRENT_REQUESTS=10

# Enable/disable embedding caching (default: true)
# Set to 'false' to disable caching (useful for testing)
# WARNING: Disabling cache will significantly increase API costs
CACHE_ENABLED=true

# ============================================================================
# Batch Processing Configuration (KNOW-028)
# ============================================================================

# Batch size for embedding operations (default: 100)
# Number of texts to process in a single batch request
# Lower values = slower but more frequent checkpoints
# Higher values = faster but more memory usage
# EMBEDDING_BATCH_SIZE=100

# ============================================================================
# Logging Configuration (KNOW-028)
# ============================================================================

# Logging level (default: info)
# Options: debug, info, warn, error
# Use 'debug' for development, 'info' or 'warn' for production
# LOG_LEVEL=info

# ============================================================================
# Alternative: DATABASE_URL (single connection string)
# ============================================================================
# You can use DATABASE_URL instead of individual KB_DB_* variables.
# If both are set, DATABASE_URL takes precedence.
#
# Example:
# DATABASE_URL=postgresql://kbuser:yourpassword@localhost:5433/knowledgebase

# ============================================================================
# Disaster Recovery Configuration (KNOW-015)
# ============================================================================

# Local backup storage path (default: ./backups)
# Backups will be stored as: {path}/kb-backup-YYYYMMDD-HHMMSS.sql.gz
KB_BACKUP_LOCAL_PATH=./backups

# PostgreSQL SSL mode for backup connections
# Options:
#   - disable: No SSL (local development only)
#   - require: Require SSL but don't verify certificate (basic protection)
#   - verify-full: Require SSL and verify server certificate (production)
# SECURITY: Use 'require' or 'verify-full' for any non-local environment
KB_DB_SSLMODE=disable

# Daily backup retention (days)
# Backups older than this will be deleted by cleanup script
# Default: 7 days
KB_BACKUP_RETENTION_DAILY=7

# Weekly backup retention (weeks)
# Sunday backups are kept for this many weeks
# Default: 4 weeks
KB_BACKUP_RETENTION_WEEKLY=4

# Monthly backup retention (months)
# First-of-month backups are kept for this many months
# Default: 12 months
KB_BACKUP_RETENTION_MONTHLY=12

# Gzip compression level (1-9)
# Higher = smaller files but slower compression
# Default: 6 (good balance)
KB_BACKUP_COMPRESSION_LEVEL=6
