# App Wishlist Gallery Environment Configuration

# Server Configuration (REQUIRED)
# This port MUST match what Playwright tests expect (see apps/web/playwright/.env)
VITE_PORT=3000

# Serverless API Configuration (REQUIRED)
VITE_SERVERLESS_API_BASE_URL=http://localhost:9000

# Module Configuration
VITE_MODULE_NAME=app-wishlist-gallery
VITE_SHELL_APP_URL=http://localhost:3000

# Application Configuration
VITE_APP_NAME=App Wishlist Gallery
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_PERFORMANCE_MONITORING=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_MSW=false

