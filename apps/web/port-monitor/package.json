{
  "name": "@repo/port-monitor",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "Port Monitor module for viewing service health status",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build:check": "vite build && tsc",
    "serve": "vite preview",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --fix",
    "format": "prettier --write src/",
    "check": "prettier --write src/ && eslint --fix src/",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "@repo/app-component-library": "workspace:*",
    "@repo/charts": "workspace:*",
    "@repo/design-system": "workspace:*",
    "@repo/logger": "workspace:*",
    "lucide-react": "^0.476.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "tailwindcss": "3.4.17",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "@vitest/coverage-v8": "4.0.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.30.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^4.0.13"
  }
}
