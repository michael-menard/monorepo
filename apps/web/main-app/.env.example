# Main Shell App Environment Configuration

# Serverless API Configuration
VITE_SERVERLESS_API_BASE_URL=https://api.execute-api.us-east-1.amazonaws.com/prod
VITE_SERVERLESS_API_TIMEOUT=15000
VITE_SERVERLESS_API_RETRY_ATTEMPTS=3

# AWS Amplify Configuration
# Get these values from: aws cloudformation describe-stacks --stack-name lego-auth-dev --query 'Stacks[0].Outputs'
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_AWS_USER_POOL_WEB_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Application Configuration
VITE_APP_NAME=LEGO MOC Instructions
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_ERROR_REPORTING=true

# Module Loading Configuration
VITE_ENABLE_MODULE_PRELOADING=true
VITE_MODULE_LOAD_TIMEOUT=10000
