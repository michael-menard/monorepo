# Playwright Test Environment
#
# Copy this file to .env and fill in the values.
# IMPORTANT: These values MUST match your deployment configuration.

# API Configuration
API_BASE_URL=http://localhost:9100

# Cognito Configuration (REQUIRED)
# Get these values from your AWS Cognito console or deployment output
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=
VITE_AWS_USER_POOL_WEB_CLIENT_ID=
