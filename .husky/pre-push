# Pre-push hook
# Run SonarQube scan before pushing - uncomment to enable
# NOTE: Requires SonarQube to be running (pnpm sonar:up)
# Uncomment the lines below to enable

# echo "🔍 Running SonarQube scan..."
# pnpm sonar:scan || { echo "❌ SonarQube scan failed"; exit 1; }
