### Gatekeeper Sidecar HTTP Integration Tests
### WINT-3010: Create Gatekeeper Sidecar
### Base URL: http://localhost:3094
### Start server: pnpm --filter @repo/gatekeeper-sidecar start

###############################################################################
# POST_BOOTSTRAP stage — PASS
###############################################################################

### POST_BOOTSTRAP — valid proof (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "setup_complete": true,
    "worktree_path": "/tree/story/WINT-3010"
  }
}

###############################################################################
# POST_BOOTSTRAP stage — FAIL (missing proofs)
###############################################################################

### POST_BOOTSTRAP — setup_complete=false (expect 422 ok:false with missing_proofs)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "setup_complete": false,
    "worktree_path": ""
  }
}

###############################################################################
# ELAB_COMPLETE stage — PASS
###############################################################################

### ELAB_COMPLETE — PASS verdict (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "ELAB_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "elab_verdict": "PASS",
    "gaps_resolved": true
  }
}

