POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "ELAB_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "elab_verdict": "CONDITIONAL_PASS",
    "gaps_resolved": true
  }
}

