###############################################################################
# SCOPE_OK stage — PASS
###############################################################################

### SCOPE_OK — normal scope with touched files (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "touched_files": 8,
    "no_scope_files": false
  }
}

### SCOPE_OK — empty scope (no_scope_files=true, touched_files=0, boundary condition, expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "touched_files": 0,
    "no_scope_files": true
  }
}

###############################################################################
# SCOPE_OK stage — FAIL
###############################################################################

### SCOPE_OK — no_scope_files=false, touched_files=0 (expect 422 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "touched_files": 0,
    "no_scope_files": false
  }
}

###############################################################################
# PATCH_COMPLETE stage — PASS
###############################################################################

### PATCH_COMPLETE — all passing at 80% coverage boundary (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "PATCH_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "build_passed": true,
    "tests_passed": true,
    "coverage_pct": 80
  }
}

###############################################################################
# PATCH_COMPLETE stage — FAIL
###############################################################################

### PATCH_COMPLETE — coverage_pct=79 (below boundary, expect 422 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "PATCH_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "story_id": "WINT-3010",
    "build_passed": true,
    "tests_passed": true,
    "coverage_pct": 79
  }
}

###############################################################################
# Error cases
###############################################################################

### Invalid JSON body (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

not-valid-json

### Empty body (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json


### Invalid stage value (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "UNKNOWN_STAGE",
  "story_id": "WINT-3010",
  "proof": {}
}

### Missing required field story_id (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "proof": {
    "story_id": "WINT-3010",
    "setup_complete": true,
    "worktree_path": "/path"
  }
}

### Method not allowed — GET (expect 405 ok:false)
GET http://localhost:3094/gate/check

### Unknown path (expect 404 ok:false)
POST http://localhost:3094/unknown/path
Content-Type: application/json

{}
