###############################################################################
# SCOPE_OK stage — PASS
###############################################################################

### SCOPE_OK — non-empty included_files (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "scope": {
      "included_files": [
        "packages/backend/sidecars/gatekeeper/src/gate-check.ts",
        "packages/backend/sidecars/gatekeeper/src/server.ts"
      ]
    }
  }
}

### SCOPE_OK — no_scope_files:true escape hatch (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "scope": {
      "no_scope_files": true
    }
  }
}

###############################################################################
# SCOPE_OK stage — FAIL
###############################################################################

### SCOPE_OK — empty included_files and no_scope_files:false (expect 422 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "SCOPE_OK",
  "story_id": "WINT-3010",
  "proof": {
    "scope": {
      "included_files": [],
      "no_scope_files": false
    }
  }
}

