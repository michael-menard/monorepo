### Gatekeeper Sidecar HTTP Integration Tests
### WINT-3010: Create Gatekeeper Sidecar
### Base URL: http://localhost:3094
### Start server: pnpm --filter @repo/gatekeeper-sidecar start

###############################################################################
# POST_BOOTSTRAP stage — PASS
###############################################################################

### POST_BOOTSTRAP — valid proof (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "story_id": "WINT-3010",
  "proof": {
    "checkpoint": {
      "phase": "setup_complete"
    }
  }
}

###############################################################################
# POST_BOOTSTRAP stage — FAIL (missing proofs)
###############################################################################

### POST_BOOTSTRAP — missing checkpoint.phase (expect 422 ok:false with missing_proofs)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "story_id": "WINT-3010",
  "proof": {
    "checkpoint": {}
  }
}

###############################################################################
# ELAB_COMPLETE stage — PASS
###############################################################################

### ELAB_COMPLETE — PASS verdict (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "ELAB_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "elab": {
      "verdict": "PASS",
      "findings": ["AC coverage complete", "No gaps found"]
    }
  }
}

### ELAB_COMPLETE — CONDITIONAL_PASS verdict (expect 200 ok:true)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "ELAB_COMPLETE",
  "story_id": "WINT-3010",
  "proof": {
    "elab": {
      "verdict": "CONDITIONAL_PASS",
      "findings": ["Minor gaps noted but non-blocking"]
    }
  }
}

