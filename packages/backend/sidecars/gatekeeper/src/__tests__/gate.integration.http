###############################################################################
# Error cases
###############################################################################

### Invalid JSON body (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

not-valid-json

### Empty body (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json


### Invalid stage value (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "UNKNOWN_STAGE",
  "story_id": "WINT-3010",
  "proof": {}
}

### Missing required field story_id (expect 400 ok:false)
POST http://localhost:3094/gate/check
Content-Type: application/json

{
  "stage": "POST_BOOTSTRAP",
  "proof": {
    "checkpoint": {
      "phase": "setup_complete"
    }
  }
}

### Method not allowed — GET (expect 405 ok:false)
GET http://localhost:3094/gate/check

### Unknown path (expect 404 ok:false)
POST http://localhost:3094/unknown/path
Content-Type: application/json

{}
