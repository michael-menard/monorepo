{
  "name": "@repo/gatekeeper-sidecar",
  "version": "1.0.0",
  "description": "Gatekeeper sidecar service — validates stage-specific proof artifacts via POST /gate/check",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "@repo/sidecar-http-utils": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "25.2.1",
    "@vitest/coverage-v8": "2.1.9",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "gatekeeper",
    "sidecar",
    "mcp"
  ]
}
