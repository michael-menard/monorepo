{
  "name": "@repo/context-pack-sidecar",
  "version": "1.0.0",
  "description": "Context pack sidecar service — assembles story context from KB cache and kb_search, exposes MCP tool + HTTP endpoint",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/knowledge-base": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/sidecar-utils": "workspace:*",
    "drizzle-orm": "^0.44.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "25.2.1",
    "dotenv": "17.3.1",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "context-pack",
    "sidecar",
    "mcp"
  ]
}
