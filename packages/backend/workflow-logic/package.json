{
  "name": "@repo/workflow-logic",
  "version": "0.0.1",
  "description": "Shared business logic for workflow operations and state transitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./__types__": {
      "types": "./dist/__types__/index.d.ts",
      "default": "./dist/__types__/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.10",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "workflow",
    "business-logic",
    "story-status",
    "state-transitions"
  ]
}
