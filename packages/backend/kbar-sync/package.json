{
  "name": "@repo/kbar-sync",
  "version": "0.0.1",
  "description": "KBAR sync functions for bidirectional filesystem-database synchronization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./__types__": {
      "types": "./dist/__types__/index.d.ts",
      "default": "./dist/__types__/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "sync:story": "tsx scripts/sync-story.ts",
    "sync:epic": "tsx scripts/sync-epic.ts",
    "regenerate:index": "tsx scripts/regenerate-index.ts"
  },
  "dependencies": {
    "@repo/database-schema": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/logger": "workspace:*",
    "drizzle-orm": "^0.44.3",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.0.0",
    "@types/node": "^22.19.10",
    "@types/pg": "8.16.0",
    "@vitest/coverage-v8": "^3.2.4",
    "pg": "8.18.0",
    "testcontainers": "^10.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "kbar",
    "sync",
    "filesystem",
    "database"
  ]
}
