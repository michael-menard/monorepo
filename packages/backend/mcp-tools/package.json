{
  "name": "@repo/mcp-tools",
  "version": "1.0.0",
  "description": "MCP tools infrastructure for session management and workflow operations",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./session-management": {
      "types": "./src/session-management/index.ts",
      "default": "./src/session-management/index.ts"
    },
    "./context-cache/__types__": {
      "types": "./src/context-cache/__types__/index.ts",
      "default": "./src/context-cache/__types__/index.ts"
    },
    "./session-management/__types__": {
      "types": "./src/session-management/__types__/index.ts",
      "default": "./src/session-management/__types__/index.ts"
    },
    "./context-cache/context-cache-get.js": {
      "types": "./src/context-cache/context-cache-get.ts",
      "default": "./src/context-cache/context-cache-get.ts"
    },
    "./context-cache/context-cache-put.js": {
      "types": "./src/context-cache/context-cache-put.ts",
      "default": "./src/context-cache/context-cache-put.ts"
    },
    "./context-cache/context-cache-invalidate.js": {
      "types": "./src/context-cache/context-cache-invalidate.ts",
      "default": "./src/context-cache/context-cache-invalidate.ts"
    },
    "./session-management/session-create.js": {
      "types": "./src/session-management/session-create.ts",
      "default": "./src/session-management/session-create.ts"
    },
    "./session-management/session-update.js": {
      "types": "./src/session-management/session-update.ts",
      "default": "./src/session-management/session-update.ts"
    },
    "./session-management/session-complete.js": {
      "types": "./src/session-management/session-complete.ts",
      "default": "./src/session-management/session-complete.ts"
    },
    "./session-management/session-cleanup.js": {
      "types": "./src/session-management/session-cleanup.ts",
      "default": "./src/session-management/session-cleanup.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/context-pack-sidecar": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/knowledge-base": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/sidecar-rules-registry": "workspace:*",
    "@repo/workflow-logic": "workspace:*",
    "drizzle-orm": "^0.44.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "25.2.1",
    "dotenv": "17.3.1",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "mcp",
    "tools",
    "session-management",
    "workflow",
    "langgraph"
  ]
}
