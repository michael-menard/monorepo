{
  "name": "@repo/orchestrator",
  "version": "0.0.1",
  "description": "LangGraph orchestrator for agent workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./__types__": {
      "types": "./dist/__types__/index.d.ts",
      "default": "./dist/__types__/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.998.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/ollama": "^0.1.0",
    "@langchain/openai": "0.3.17",
    "@repo/knowledge-base": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/mcp-tools": "workspace:*",
    "@repo/workflow-logic": "workspace:*",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.0",
    "pg": "8.18.0",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/axe-core": "3.0.6",
    "@types/inquirer": "^9.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^22.19.10",
    "@types/pg": "8.16.0",
    "@vitest/coverage-v8": "^3.2.4",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.44.7",
    "tsx": "4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "langgraph",
    "orchestrator",
    "agent",
    "workflow"
  ]
}
