{
  "name": "@repo/cache",
  "version": "1.0.0",
  "description": "Shared caching utilities for the monorepo",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/schemas/cache.d.ts",
      "import": "./dist/schemas/cache.js"
    },
    "./utils/memoryCache": {
      "types": "./dist/utils/memoryCache.d.ts",
      "import": "./dist/utils/memoryCache.js"
    },
    "./utils/storageCache": {
      "types": "./dist/utils/storageCache.d.ts",
      "import": "./dist/utils/storageCache.js"
    },
    "./utils/imageCache": {
      "types": "./dist/utils/imageCache.d.ts",
      "import": "./dist/utils/imageCache.js"
    },
    "./utils/rtkQueryCache": {
      "types": "./dist/utils/rtkQueryCache.d.ts",
      "import": "./dist/utils/rtkQueryCache.js"
    },
    "./utils/serverlessCache": {
      "types": "./dist/utils/serverlessCache.d.ts",
      "import": "./dist/utils/serverlessCache.js"
    },
    "./utils/performanceMonitor": {
      "types": "./dist/utils/performanceMonitor.d.ts",
      "import": "./dist/utils/performanceMonitor.js"
    },
    "./utils/serverlessCacheManager": {
      "types": "./dist/utils/serverlessCacheManager.d.ts",
      "import": "./dist/utils/serverlessCacheManager.js"
    },
    "./managers/IntelligentCacheManager": {
      "types": "./dist/managers/IntelligentCacheManager.d.ts",
      "import": "./dist/managers/IntelligentCacheManager.js"
    },
    "./rtk/IntelligentRTKCacheEnhancer": {
      "types": "./dist/rtk/IntelligentRTKCacheEnhancer.d.ts",
      "import": "./dist/rtk/IntelligentRTKCacheEnhancer.js"
    },
    "./analytics/CacheAnalytics": {
      "types": "./dist/analytics/CacheAnalytics.d.ts",
      "import": "./dist/analytics/CacheAnalytics.js"
    },
    "./hooks/useServerlessCache": {
      "types": "./dist/hooks/useServerlessCache.d.ts",
      "import": "./dist/hooks/useServerlessCache.js"
    },
    "./hooks/useIntelligentCache": {
      "types": "./dist/hooks/useIntelligentCache.d.ts",
      "import": "./dist/hooks/useIntelligentCache.js"
    },
    "./schemas/cache": {
      "types": "./dist/schemas/cache.d.ts",
      "import": "./dist/schemas/cache.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix src/",
    "format": "prettier --write src/",
    "check": "prettier --write src/ && eslint --fix src/",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "eslint": "^9.30.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "5.8.3",
    "vite": "^5.2.10",
    "vite-plugin-dts": "4.5.4",
    "vitest": "^3.0.5"
  }
}
