# Serverless API Configuration
# Copy this file to .env.development, .env.staging, .env.production, etc.

# Required: Base URL for the serverless API
VITE_SERVERLESS_API_BASE_URL=https://your-api-gateway.execute-api.region.amazonaws.com/stage

# Optional: Request timeout in milliseconds (default: 15000)
VITE_SERVERLESS_API_TIMEOUT=15000

# Optional: Number of retry attempts for failed requests (default: 3)
VITE_SERVERLESS_API_RETRY_ATTEMPTS=3

# Optional: Base delay between retries in milliseconds (default: 1000)
VITE_SERVERLESS_API_RETRY_DELAY=1000

# Optional: Maximum delay between retries in milliseconds (default: 10000)
VITE_SERVERLESS_API_MAX_RETRY_DELAY=10000

# Optional: Enable connection warming (default: true)
VITE_SERVERLESS_CONNECTION_WARMING=true

# Example configurations for different environments:

# Development (local serverless)
# VITE_SERVERLESS_API_BASE_URL=http://localhost:3001
# VITE_SERVERLESS_API_TIMEOUT=30000
# VITE_SERVERLESS_API_RETRY_ATTEMPTS=5

# Staging
# VITE_SERVERLESS_API_BASE_URL=https://staging-api.execute-api.us-east-1.amazonaws.com/staging
# VITE_SERVERLESS_API_TIMEOUT=20000
# VITE_SERVERLESS_API_RETRY_ATTEMPTS=3

# Production
# VITE_SERVERLESS_API_BASE_URL=https://api.execute-api.us-east-1.amazonaws.com/prod
# VITE_SERVERLESS_API_TIMEOUT=15000
# VITE_SERVERLESS_API_RETRY_ATTEMPTS=3
