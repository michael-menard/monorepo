{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/deepseek-v4-flash:cloud",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "deepseek-v4-flash:cloud": {
          "name": "DeepSeek V4 Flash (Cloud)"
        },
        "kimi-k2.6:cloud": {
          "name": "Kimi K2.6 (Cloud)"
        },
        "glm-5.1:cloud": {
          "name": "GLM 5.1 (Cloud)"
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5 (Cloud)"
        },
        "minimax-m2.7:cloud": {
          "name": "MiniMax M2.7 (Cloud)"
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen 2.5 Coder 14B (Local)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (Local)"
        }
      }
    }
  },
  "mcp": {
    "knowledge-base": {
      "type": "local",
      "command": [
        "/bin/sh",
        "-c",
        "set -a && . /Users/michaelmenard/Development/monorepo/apps/api/knowledge-base/.env && set +a && exec /Users/michaelmenard/.asdf/installs/nodejs/23.11.1/bin/node /Users/michaelmenard/Development/monorepo/apps/api/knowledge-base/dist/mcp-server/index.js"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    }
  },
  "tools": {
    "knowledge-base": true,
    "context7": true
  }
}
