# SonarQube Configuration
# Generate a token in SonarQube UI (http://localhost:9000)
# Profile → My Account → Security → Generate Token
SONAR_TOKEN=your_sonarqube_token_here

# SonarQube Host URL (default for local development)
SONAR_HOST_URL=http://localhost:9001

# ─────────────────────────────────────────────────────────────────────────────
# Autonomous Pipeline (apps/api/pipeline)
# AUDIT-8: Emergency Controls — all vars here affect runtime pipeline behaviour
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL (required for supervisor + scheduler + CLI)
REDIS_URL=redis://localhost:6379

# BullMQ queue name (default: apip-pipeline — do NOT change after first deployment)
PIPELINE_QUEUE_NAME=apip-pipeline

# ─── Concurrency ──────────────────────────────────────────────────────────────
# Max parallel LangGraph runs dispatched by the scheduler (default: 3, max: 10)
# Set to 1 for serial/safe mode before the first real pipeline run.
# AUDIT-8: Emergency — lower this first before pausing to reduce blast radius.
SCHEDULER_MAX_CONCURRENT=3

# ─── Timeouts ─────────────────────────────────────────────────────────────────
# Max wall-clock time for a single graph execution in ms (default: 600000 = 10 min)
PIPELINE_STAGE_TIMEOUT_MS=600000

# Max time to wait for in-flight jobs to drain on SIGTERM (default: 600000 = 10 min)
SUPERVISOR_DRAIN_TIMEOUT_MS=600000

# ─── Scheduler ────────────────────────────────────────────────────────────────
# How often the scheduler polls KB for eligible stories in ms (default: 30000 = 30s)
SCHEDULER_POLL_INTERVAL_MS=30000

# ─── Health server ────────────────────────────────────────────────────────────
# Port for GET /health and GET /live (default: 9091)
SUPERVISOR_HEALTH_PORT=9091

# ─── Notifications ────────────────────────────────────────────────────────────
# Webhook URL for blocker notifications (optional — leave blank to disable)
PIPELINE_NOTIFICATION_WEBHOOK_URL=

# ─── KB database (required for quarantine and scheduler) ──────────────────────
# Password for the KB PostgreSQL database
KB_DB_PASSWORD=
