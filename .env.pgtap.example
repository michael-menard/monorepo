# .env.pgtap.example
#
# Copy this file to .env.local and fill in PGTAP_DB_PASS.
# .env.local is git-ignored and must never be committed.
#
# These credentials are for the local ephemeral pgtap test database only.
# They are never shared, never used in production.
# CI uses the PGTAP_DB_PASSWORD GitHub Secret instead.

PGTAP_DB_USER=pgtap
PGTAP_DB_PASS=change-me-local-only
PGTAP_DB_NAME=pgtap_test
PGTAP_DB_PORT=5434
PGTAP_DB_HOST=localhost
