{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "WebSearch",
      "WebFetch(domain:*)",
      "Bash",
      "mcp__github__*",
      "mcp__chrome-devtools__*",
      "mcp__knowledge-base__*"
    ],

    "ask": [
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean:*)",
      "Bash(npx drizzle-kit push:*)",
      "Bash(npx drizzle-kit migrate:*)",
      "Bash(npx drizzle-kit drop:*)",
      "Bash(npx drizzle-kit generate:*)",
      "Bash(sst deploy:*)",
      "Bash(sst remove:*)",
      "Bash(aws :*)"
    ],

    "deny": [
      "Write(./node_modules/**)",
      "Edit(./node_modules/**)",
      "Write(./.git/**)",
      "Edit(./.git/**)",
      "Bash(rm -rf:*)",
      "Bash(rm :*)"
    ]
  },
  "trust": {
    "allowSelfEdit": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "/(pm-story|dev-implement-story|qa-verify-story)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[CONTEXT WARNING] Long-running workflow command detected. If this is a new story or you are switching context, run /clear first to prevent prior session context from interfering. If you have already cleared, ignore this message.'"
          }
        ]
      }
    ]
  }
}
